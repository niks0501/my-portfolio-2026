---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import ContactFooter from '../components/ContactFooter.astro';
import { getJsonLdPerson, getJsonLdWebsite } from '../lib/seo';

const title = 'Nikko Causapin — Software Engineer & Web Developer';
const description =
  'Portfolio of Nikko Causapin, a BSIT Business Analytics student building full-stack web apps, internal tools, and data-driven systems.';

const jsonLd = [getJsonLdPerson(), { ...getJsonLdWebsite(), description }];
---

<BaseLayout
  title={title}
  description={description}
  type="profile"
  jsonLd={jsonLd}
>
  <Navbar />
  <main id="main" tabindex="-1">
    <Hero />
    <ProjectsSection />
    <AboutSection />
    <ServicesSection />
    <ContactFooter />
  </main>
  <script>
    import '../scripts/scroll-reveal.js';
    import '../scripts/projects-filter.js';
  </script>
</BaseLayout>
