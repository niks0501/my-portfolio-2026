---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
---

<BaseLayout
  title="Page Not Found — Nikko Causapin"
  description="The page you are looking for does not exist. Return to Nikko Causapin's portfolio."
  canonicalPath="/404/"
>
  <Navbar />
  <main
    id="main"
    tabindex="-1"
    class="min-h-screen flex items-center pt-24 pb-16"
  >
    <section class="max-w-4xl mx-auto px-6">
      <p
        class="text-xs font-medium uppercase tracking-[0.18em] text-primary mb-4"
      >
        404 — Not found
      </p>
      <h1
        class="text-4xl md:text-6xl font-semibold leading-tight text-foreground text-balance"
      >
        This route does not exist.
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed mt-5 max-w-xl">
        The portfolio is intentionally small: selected projects, current focus,
        and contact details. Head back home to continue browsing.
      </p>
      <a
        href="/"
        class="inline-flex items-center bg-primary text-primary-foreground px-5 py-3 rounded-md font-medium hover:brightness-90 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background transition-[filter] cursor-pointer mt-8"
      >
        Back home
      </a>
    </section>
  </main>
</BaseLayout>
