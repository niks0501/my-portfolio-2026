---
import { Icon } from 'astro-icon/components';
---

<section
  id="hero"
  class="relative overflow-hidden bg-gradient-to-br from-primary/[0.04] via-background to-background"
>
  <div
    class="absolute inset-0 overflow-hidden pointer-events-none -z-10"
    aria-hidden="true"
  >
    <div
      class="absolute top-1/4 right-1/4 w-[32rem] h-[32rem] bg-primary/[0.06] rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-1/4 left-1/3 w-[24rem] h-[24rem] bg-primary/[0.05] rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[40rem] h-[40rem] bg-blue-500/[0.03] rounded-full blur-[120px] dark:opacity-100 opacity-0"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]"
      style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 40px 40px;"
    >
    </div>
  </div>
  <div
    class="max-w-6xl lg:max-w-7xl mx-auto px-6 pt-20 pb-16 md:pt-28 md:pb-24"
  >
    <div
      class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16"
    >
      <div class="flex-1 text-center md:text-left">
        <div
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[var(--glass-bg-hover)] backdrop-blur-xl border border-[color:var(--glass-border)] text-xs text-foreground/90 mb-6 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards"
        >
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Available for hire
        </div>

        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-semibold leading-tight text-foreground animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-100"
        >
          Nikko Causapin
        </h1>
        <p
          class="text-2xl md:text-3xl text-primary font-medium mt-2 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-200"
        >
          Software Engineer & Web Developer
        </p>
        <p
          class="text-lg text-muted-foreground mt-4 max-w-xl mx-auto md:mx-0 leading-relaxed animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-300"
        >
          I build data-aware web apps and internal tools that turn messy
          workflows into clear, usable systems.
        </p>

        <div
          class="flex flex-wrap gap-5 md:gap-8 mt-7 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-350"
        >
          <button
            type="button"
            data-badge-index="0"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
            aria-label="View Microsoft Office Specialist Excel badge"
          >
            <img
              src="/images/badges/microsoft-office-specialist-excel-office-2016.png"
              alt="Microsoft Office Specialist — Excel"
              width="64"
              height="64"
              class="w-16 h-16"
              loading="lazy"
            />
            <span
              class="text-sm text-muted-foreground text-center leading-tight cursor-text dark:text-foreground/[0.85]"
            >
              MOS<br />Excel
            </span>
          </button>
          <button
            type="button"
            data-badge-index="1"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
            aria-label="View IT Specialist Data Analytics badge"
          >
            <img
              src="/images/badges/it-specialist-data-analytics.png"
              alt="IT Specialist — Data Analytics"
              width="64"
              height="64"
              class="w-16 h-16"
              loading="lazy"
            />
            <span
              class="text-sm text-muted-foreground text-center leading-tight cursor-text dark:text-foreground/[0.85]"
            >
              Data<br />Analytics
            </span>
          </button>
          <button
            type="button"
            data-badge-index="2"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
            aria-label="View IT Specialist Device Configuration and Management badge"
          >
            <img
              src="/images/badges/it-specialist-device-configuration-and-management.png"
              alt="IT Specialist — Device Configuration and Management"
              width="64"
              height="64"
              class="w-16 h-16"
              loading="lazy"
            />
            <span
              class="text-sm text-muted-foreground text-center leading-tight cursor-text dark:text-foreground/[0.85]"
            >
              Device Config<br />&amp; Management
            </span>
          </button>
          <button
            type="button"
            data-badge-index="3"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
            aria-label="View IT Specialist Databases badge"
          >
            <img
              src="/images/badges/it-specialist-databases.png"
              alt="IT Specialist — Databases"
              width="64"
              height="64"
              class="w-16 h-16"
              loading="lazy"
            />
            <span
              class="text-sm text-muted-foreground text-center leading-tight cursor-text dark:text-foreground/[0.85]"
            >
              Databases
            </span>
          </button>
        </div>

        <div
          class="flex flex-wrap items-center gap-3 mt-8 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-400"
        >
          <a
            href="#projects"
            class="inline-flex items-center bg-primary text-primary-foreground px-6 py-3 rounded-md text-base font-medium hover:brightness-90 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-[filter] cursor-pointer"
          >
            View My Projects
          </a>
          <a
            href="mailto:nikkocausapin61@gmail.com"
            class="inline-flex items-center border border-border text-foreground px-6 py-3 rounded-md text-base font-medium hover:bg-muted focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-colors cursor-pointer"
          >
            Get in Touch
          </a>
        </div>

        <div
          class="mt-6 flex flex-wrap items-center gap-3 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-500"
          aria-label="Tech stack"
        >
          <span
            class="group relative w-12 h-12 rounded-full bg-muted/80 ring-1 ring-foreground/15 flex items-center justify-center transition-colors hover:bg-muted dark:bg-white/10 dark:ring-white/20 dark:hover:bg-white/15"
          >
            <Icon
              name="logos:laravel"
              class="w-6 h-6 shrink-0"
              aria-label="Laravel"
            />
            <span
              role="tooltip"
              class="tech-tooltip pointer-events-none absolute top-full left-1/2 -translate-x-1/2 mt-2 px-2 py-1 rounded-md bg-foreground text-background text-xs font-medium whitespace-nowrap opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 z-10"
            >
              Laravel
            </span>
          </span>
          <span
            class="group relative w-12 h-12 rounded-full bg-muted/80 ring-1 ring-foreground/15 flex items-center justify-center transition-colors hover:bg-muted dark:bg-white/10 dark:ring-white/20 dark:hover:bg-white/15"
          >
            <Icon
              name="logos:react"
              class="w-6 h-6 shrink-0"
              aria-label="React"
            />
            <span
              role="tooltip"
              class="tech-tooltip pointer-events-none absolute top-full left-1/2 -translate-x-1/2 mt-2 px-2 py-1 rounded-md bg-foreground text-background text-xs font-medium whitespace-nowrap opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 z-10"
            >
              React
            </span>
          </span>
          <span
            class="group relative w-12 h-12 rounded-full bg-muted/80 ring-1 ring-foreground/15 flex items-center justify-center transition-colors hover:bg-muted dark:bg-white/10 dark:ring-white/20 dark:hover:bg-white/15"
          >
            <Icon
              name="logos:mysql-icon"
              class="w-6 h-6 shrink-0"
              aria-label="MySQL"
            />
            <span
              role="tooltip"
              class="tech-tooltip pointer-events-none absolute top-full left-1/2 -translate-x-1/2 mt-2 px-2 py-1 rounded-md bg-foreground text-background text-xs font-medium whitespace-nowrap opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 z-10"
            >
              MySQL
            </span>
          </span>
          <span
            class="group relative w-12 h-12 rounded-full bg-muted/80 ring-1 ring-foreground/15 flex items-center justify-center transition-colors hover:bg-muted dark:bg-white/10 dark:ring-white/20 dark:hover:bg-white/15"
          >
            <Icon
              name="logos:tailwindcss-icon"
              class="w-6 h-6 shrink-0"
              aria-label="Tailwind CSS"
            />
            <span
              role="tooltip"
              class="tech-tooltip pointer-events-none absolute top-full left-1/2 -translate-x-1/2 mt-2 px-2 py-1 rounded-md bg-foreground text-background text-xs font-medium whitespace-nowrap opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 z-10"
            >
              Tailwind CSS
            </span>
          </span>
          <span
            class="group relative w-12 h-12 rounded-full bg-muted/80 ring-1 ring-foreground/15 flex items-center justify-center transition-colors hover:bg-muted dark:bg-white/10 dark:ring-white/20 dark:hover:bg-white/15"
          >
            <Icon
              name="logos:git-icon"
              class="w-6 h-6 shrink-0"
              aria-label="Git"
            />
            <span
              role="tooltip"
              class="tech-tooltip pointer-events-none absolute top-full left-1/2 -translate-x-1/2 mt-2 px-2 py-1 rounded-md bg-foreground text-background text-xs font-medium whitespace-nowrap opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 z-10"
            >
              Git
            </span>
          </span>
          <span
            class="group relative w-12 h-12 rounded-full bg-muted/80 ring-1 ring-foreground/15 flex items-center justify-center transition-colors hover:bg-muted dark:bg-white/10 dark:ring-white/20 dark:hover:bg-white/15"
          >
            <Icon name="logos:vue" class="w-6 h-6 shrink-0" aria-label="Vue" />
            <span
              role="tooltip"
              class="tech-tooltip pointer-events-none absolute top-full left-1/2 -translate-x-1/2 mt-2 px-2 py-1 rounded-md bg-foreground text-background text-xs font-medium whitespace-nowrap opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 z-10"
            >
              Vue
            </span>
          </span>
        </div>
      </div>

      <div
        class="shrink-0 animate-in fade-in slide-in-from-right-4 duration-500 fill-mode-forwards delay-150"
      >
        <div class="relative">
          <img
            src="/images/profile.webp"
            alt="Nikko Causapin, software engineer and web developer"
            width="768"
            height="768"
            class="w-72 h-72 md:w-96 md:h-96 rounded-full object-cover border-4 border-border shadow-xl"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <div
            class="absolute -inset-4 rounded-full border-2 border-primary/20 -z-10"
          >
          </div>
        </div>
      </div>
    </div>
  </div>

  <dialog
    id="badge-modal"
    class="backdrop:bg-black/50 rounded-2xl p-6 w-[560px] max-w-[95vw] max-h-[90vh] border border-border bg-background text-foreground overflow-hidden dark:bg-card dark:shadow-2xl"
    aria-labelledby="modal-title"
  >
    <div class="flex justify-end">
      <form method="dialog">
        <button
          type="submit"
          class="text-muted-foreground hover:text-foreground text-xl leading-none cursor-pointer rounded-full w-8 h-8 flex items-center justify-center hover:bg-muted transition-colors"
          aria-label="Close"
        >
          &times;
        </button>
      </form>
    </div>
    <div class="flex flex-col items-center gap-5">
      <div class="flex items-center justify-center gap-4">
        <button
          type="button"
          data-nav-dir="-1"
          class="text-muted-foreground hover:text-foreground hover:bg-muted text-3xl shrink-0 cursor-pointer rounded-xl w-12 h-12 flex items-center justify-center transition-colors"
          aria-label="Previous"
        >
          &larr;
        </button>
        <div
          class="flex-1 min-w-0 h-[400px] flex items-center justify-center overflow-hidden"
        >
          <img
            id="modal-img"
            src=""
            alt=""
            class="max-w-full max-h-full object-contain rounded-lg"
          />
        </div>
        <button
          type="button"
          data-nav-dir="1"
          class="text-muted-foreground hover:text-foreground hover:bg-muted text-3xl shrink-0 cursor-pointer rounded-xl w-12 h-12 flex items-center justify-center transition-colors"
          aria-label="Next"
        >
          &rarr;
        </button>
      </div>
      <div class="text-center">
        <h3 id="modal-title" class="text-lg font-semibold text-foreground"></h3>
        <p id="modal-category" class="text-sm text-muted-foreground mt-0.5"></p>
      </div>
      <div class="flex items-center gap-2">
        <div id="modal-dots" class="flex gap-1.5"></div>
        <span id="modal-counter" class="text-xs text-muted-foreground ml-1"
          >1 / 4</span
        >
      </div>
    </div>
  </dialog>
</section>

<style>
  .tech-tooltip::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-bottom-color: var(--color-foreground, currentColor);
  }

  #badge-modal[open] {
    animation: modal-in 0.2s ease-out;
  }

  #badge-modal[open]::backdrop {
    animation: backdrop-in 0.2s ease-out;
  }

  @keyframes modal-in {
    from {
      opacity: 0;
      transform: scale(0.92);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #badge-modal {
    margin: auto;
  }

  #badge-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  function initBadgeGallery() {
    const badges = [
      {
        src: '/images/badges/microsoft-office-specialist-excel-office-2016.png',
        name: 'Microsoft Office Specialist \u2014 Excel',
        category: 'Microsoft Office Specialist',
      },
      {
        src: '/images/badges/it-specialist-data-analytics.png',
        name: 'IT Specialist \u2014 Data Analytics',
        category: 'IT Specialist',
      },
      {
        src: '/images/badges/it-specialist-device-configuration-and-management.png',
        name: 'IT Specialist \u2014 Device Configuration and Management',
        category: 'IT Specialist',
      },
      {
        src: '/images/badges/it-specialist-databases.png',
        name: 'IT Specialist \u2014 Databases',
        category: 'IT Specialist',
      },
    ];

    let currentIndex = 0;
    const dialog = document.getElementById('badge-modal');
    const img = document.getElementById('modal-img');
    const title = document.getElementById('modal-title');
    const categoryEl = document.getElementById('modal-category');
    const counter = document.getElementById('modal-counter');
    const dots = document.getElementById('modal-dots');

    if (
      !(dialog instanceof HTMLDialogElement) ||
      !(img instanceof HTMLImageElement)
    )
      return;

    const badgeDialog = dialog;
    const modalImg = img;

    function buildDots() {
      if (!dots) return;
      dots.innerHTML = '';
      badges.forEach((_, i) => {
        const dot = document.createElement('span');
        dot.className =
          'w-2 h-2 rounded-full transition-colors ' +
          (i === currentIndex ? 'bg-primary' : 'bg-border');
        dots.appendChild(dot);
      });
    }

    function updateModal() {
      const badge = badges[currentIndex];
      if (!badge) return;
      modalImg.src = badge.src;
      modalImg.alt = badge.name;
      if (title) title.textContent = badge.name;
      if (categoryEl) categoryEl.textContent = badge.category;
      if (counter)
        counter.textContent = currentIndex + 1 + ' / ' + badges.length;
      const dotEls = dots?.children;
      if (dotEls) {
        for (let i = 0; i < dotEls.length; i++) {
          const dot = dotEls[i];
          if (!dot) continue;
          dot.className =
            'w-2 h-2 rounded-full transition-colors ' +
            (i === currentIndex ? 'bg-primary' : 'bg-border');
        }
      }
    }

    function show(index: number) {
      currentIndex = index;
      updateModal();
      badgeDialog.showModal();
    }

    function navigate(dir: number) {
      currentIndex = (currentIndex + dir + badges.length) % badges.length;
      updateModal();
    }

    buildDots();

    document
      .querySelectorAll<HTMLElement>('[data-badge-index]')
      .forEach((el) => {
        el.addEventListener('click', () => {
          const index = Number(el.dataset.badgeIndex);
          if (Number.isFinite(index)) show(index);
        });
      });

    document.querySelectorAll<HTMLElement>('[data-nav-dir]').forEach((el) => {
      el.addEventListener('click', () => {
        const dir = Number(el.dataset.navDir);
        if (Number.isFinite(dir)) navigate(dir);
      });
    });

    badgeDialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });

    badgeDialog.addEventListener('click', (e) => {
      const rect = badgeDialog.getBoundingClientRect();
      const isOutside =
        e.clientX < rect.left ||
        e.clientX > rect.right ||
        e.clientY < rect.top ||
        e.clientY > rect.bottom;
      if (isOutside) badgeDialog.close();
    });
  }

  initBadgeGallery();
  document.addEventListener('astro:after-swap', initBadgeGallery);
</script>
