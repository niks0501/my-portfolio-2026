---
---

<section
  id="hero"
  class="relative overflow-hidden bg-gradient-to-br from-primary/[0.04] via-background to-background"
>
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10" aria-hidden="true">
    <div class="absolute top-1/4 right-1/4 w-[32rem] h-[32rem] bg-primary/[0.04] rounded-full blur-3xl" />
    <div class="absolute -bottom-1/4 left-1/3 w-[24rem] h-[24rem] bg-primary/[0.03] rounded-full blur-3xl" />
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 40px 40px;"
    />
  </div>
  <div class="max-w-6xl lg:max-w-7xl mx-auto px-6 pt-20 pb-16 md:pt-28 md:pb-24">
    <div
      class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16"
    >
      <!-- Left: Text -->
      <div class="flex-1 text-center md:text-left">
        <!-- Status badge -->
        <div
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-border text-xs text-muted-foreground mb-6 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards"
        >
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
          Available for hire
        </div>

        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-semibold leading-tight text-foreground animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-100"
        >
          Nikko Causapin
        </h1>
        <p
          class="text-2xl md:text-3xl text-primary font-medium mt-2 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-200"
        >
          Software Engineer & Web Developer
        </p>
        <p
          class="text-lg text-muted-foreground mt-4 max-w-xl mx-auto md:mx-0 leading-relaxed animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-300"
        >
          I build practical web apps and internal tools that keep workflows
          simple and decisions clear.
        </p>

        <div
          class="flex flex-wrap gap-5 md:gap-8 mt-7 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-350"
        >
          <button
            type="button"
            data-badge-index="0"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
          >
            <img
              src="/images/badges/microsoft-office-specialist-excel-office-2016.png"
              alt="Microsoft Office Specialist — Excel"
              class="w-16 h-16"
              loading="lazy"
            />
            <span class="text-sm text-muted-foreground text-center leading-tight cursor-text">
              MOS<br />Excel
            </span>
          </button>
          <button
            type="button"
            data-badge-index="1"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
          >
            <img
              src="/images/badges/it-specialist-data-analytics.png"
              alt="IT Specialist — Data Analytics"
              class="w-16 h-16"
              loading="lazy"
            />
            <span class="text-sm text-muted-foreground text-center leading-tight cursor-text">
              Data<br />Analytics
            </span>
          </button>
          <button
            type="button"
            data-badge-index="2"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
          >
            <img
              src="/images/badges/it-specialist-device-configuration-and-management.png"
              alt="IT Specialist — Device Configuration and Management"
              class="w-16 h-16"
              loading="lazy"
            />
            <span class="text-sm text-muted-foreground text-center leading-tight cursor-text">
              Device Config<br />&amp; Management
            </span>
          </button>
          <button
            type="button"
            data-badge-index="3"
            class="flex flex-col items-center gap-1.5 cursor-pointer"
          >
            <img
              src="/images/badges/it-specialist-databases.png"
              alt="IT Specialist — Databases"
              class="w-16 h-16"
              loading="lazy"
            />
            <span class="text-sm text-muted-foreground text-center leading-tight cursor-text">
              Databases
            </span>
          </button>
        </div>

        <div
          class="flex flex-wrap items-center gap-3 mt-8 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-400"
        >
          <a
            href="#projects"
            class="inline-flex items-center bg-primary text-primary-foreground px-6 py-3 rounded-md text-base font-medium hover:brightness-90 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-[filter]"
          >
            View My Projects
          </a>
          <a
            href="mailto:nikkocausapin61@gmail.com"
            class="inline-flex items-center border border-border text-foreground px-6 py-3 rounded-md text-base font-medium hover:bg-muted focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-colors"
          >
            Get in Touch
          </a>
        </div>

        <div
          class="mt-6 animate-in fade-in slide-in-from-bottom-4 duration-500 fill-mode-forwards delay-500"
        >
          <a
            href="mailto:nikkocausapin61@gmail.com"
            class="text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            nikkocausapin61@gmail.com
          </a>
        </div>
      </div>

      <!-- Right: Photo -->
      <div
        class="shrink-0 animate-in fade-in slide-in-from-right-4 duration-500 fill-mode-forwards delay-150"
      >
        <div class="relative">
          <img
            src="/images/profile.jpg"
            alt="Nikko Causapin"
            class="w-72 h-72 md:w-96 md:h-96 rounded-full object-cover border-4 border-border shadow-xl"
          />
          <!-- Decorative ring -->
          <div
            class="absolute -inset-4 rounded-full border-2 border-primary/20 -z-10"
          />
        </div>
      </div>
    </div>
  </div>

  <dialog
    id="badge-modal"
    class="backdrop:bg-black/50 rounded-2xl p-6 w-[560px] max-w-[95vw] max-h-[90vh] border border-border bg-background overflow-hidden"
  >
    <div class="flex justify-end">
      <form method="dialog">
        <button
          type="submit"
          class="text-muted-foreground hover:text-foreground text-xl leading-none cursor-pointer rounded-full w-8 h-8 flex items-center justify-center hover:bg-muted transition-colors"
          aria-label="Close"
        >
          &times;
        </button>
      </form>
    </div>
    <div class="flex flex-col items-center gap-5">
      <div class="flex items-center justify-center gap-4">
        <button
          type="button"
          data-nav-dir="-1"
          class="text-muted-foreground hover:text-foreground hover:bg-muted text-3xl shrink-0 cursor-pointer rounded-xl w-12 h-12 flex items-center justify-center transition-colors"
          aria-label="Previous"
        >
          &larr;
        </button>
        <div class="flex-1 min-w-0 h-[400px] flex items-center justify-center overflow-hidden">
          <img
            id="modal-img"
            src=""
            alt=""
            class="max-w-full max-h-full object-contain rounded-lg"
          />
        </div>
        <button
          type="button"
          data-nav-dir="1"
          class="text-muted-foreground hover:text-foreground hover:bg-muted text-3xl shrink-0 cursor-pointer rounded-xl w-12 h-12 flex items-center justify-center transition-colors"
          aria-label="Next"
        >
          &rarr;
        </button>
      </div>
      <div class="text-center">
        <h3
          id="modal-title"
          class="text-lg font-semibold text-foreground"
        ></h3>
        <p
          id="modal-category"
          class="text-sm text-muted-foreground mt-0.5"
        ></p>
      </div>
      <div class="flex items-center gap-2">
        <div id="modal-dots" class="flex gap-1.5"></div>
        <span
          id="modal-counter"
          class="text-xs text-muted-foreground ml-1"
        >1 / 4</span>
      </div>
    </div>
  </dialog>
</section>

<style>
  #badge-modal[open] {
    animation: modal-in 0.2s ease-out;
  }

  #badge-modal[open]::backdrop {
    animation: backdrop-in 0.2s ease-out;
  }

  @keyframes modal-in {
    from {
      opacity: 0;
      transform: scale(0.92);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #badge-modal {
    margin: auto;
  }

  #badge-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  import '../scripts/badge-gallery.js';
</script>

