---
interface Props {
  title: string;
  summary: string;
  highlights: string[];
  tags: string[];
  images: string[];
  githubUrl: string;
  liveDemoUrl?: string;
}

const {
  title,
  summary,
  highlights,
  tags,
  images,
  githubUrl,
  liveDemoUrl,
} = Astro.props;
---

<div class="bg-card border border-border rounded-lg overflow-hidden">
  <div class="flex">
    {
      images.length >= 3
        ? images.map((src) => (
            <img
              src={src}
              alt={`${title} — screenshot`}
              class="w-1/3 aspect-[4/3] object-cover"
              loading="lazy"
            />
          ))
        : Array.from({ length: 3 }).map(() => (
            <div class="w-1/3 aspect-[4/3] bg-muted" />
          ))
    }
  </div>
  <div class="p-6">
    <h3 class="text-xl font-semibold leading-tight text-card-foreground">
      {title}
    </h3>
    <p class="text-base text-muted-foreground mt-2">{summary}</p>
    <ul class="mt-4 space-y-1">
      {highlights.map((item) => (
        <li class="text-sm text-foreground flex items-start gap-2">
          <span class="text-muted-foreground shrink-0">&mdash;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
    <div class="flex flex-wrap gap-2 mt-4">
      {tags.map((tag) => (
        <span class="text-sm bg-primary/10 text-primary px-2 py-0.5 rounded-sm">
          {tag}
        </span>
      ))}
    </div>
    <div class="flex items-center justify-between mt-6 pt-4 border-t border-border">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-foreground hover:text-primary focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm transition-colors"
      >
        GitHub
      </a>
      {
        liveDemoUrl
          ? (
            <a
              href={liveDemoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-foreground hover:text-primary focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm transition-colors"
            >
              Live demo
            </a>
          )
          : (
            <span class="text-sm bg-muted text-muted-foreground px-3 py-1.5 rounded-md cursor-not-allowed opacity-50">
              Coming soon
            </span>
          )
      }
    </div>
  </div>
</div>
