---
const email = 'nikkocausapin61@gmail.com';
const buildSha = import.meta.env.VERCEL_GIT_COMMIT_SHA?.slice(0, 7) ?? 'local';

const contactItems = [
  {
    label: 'Email',
    value: email,
    icon: 'mail',
    href: `mailto:${email}`,
    external: false,
    available: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/niks0501',
    icon: 'github',
    href: 'https://github.com/niks0501',
    external: true,
    available: true,
  },
  {
    label: 'Location',
    value: 'Batangas, Philippines · GMT+8',
    icon: 'map-pin',
    href: null,
    external: false,
    available: true,
  },
] as const;

const iconPath: Record<string, string> = {
  mail: '<rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />',
  github:
    '<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />',
  'map-pin':
    '<path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />',
};
---

<section id="contact" class="scroll-reveal">
  <div class="max-w-4xl lg:max-w-7xl mx-auto px-6 py-16">
    <!-- Header -->
    <p
      class="text-xs font-medium uppercase tracking-[0.18em] text-primary mb-3"
    >
      05 — Contact
    </p>
    <h2
      class="text-3xl lg:text-4xl font-semibold leading-tight text-foreground text-balance"
    >
      Let's connect.
    </h2>
    <div
      class="w-12 h-px bg-gradient-to-r from-primary/60 to-transparent mt-4"
      aria-hidden="true"
    >
    </div>

    <!-- Two-column grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 mt-12">
      <!-- LEFT: Description + CTAs -->
      <div class="lg:col-span-5">
        <p class="text-base text-muted-foreground leading-relaxed">
          I'm open to internship opportunities, junior developer roles, academic
          collaborations, and small system development projects. If my work fits
          what you're looking for, feel free to reach out.
        </p>

        <div class="flex flex-col gap-2.5 mt-7">
          <a
            href={`mailto:${email}`}
            class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-5 py-3 rounded-md font-medium hover:brightness-90 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background transition-[filter] cursor-pointer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            Send Email
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>

          <button
            type="button"
            data-copy-email
            data-copy-value={email}
            class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-5 py-3 rounded-md font-medium hover:bg-muted focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background transition-colors cursor-pointer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="14" height="14" x="8" y="8" rx="2"></rect>
              <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
              ></path>
            </svg>
            <span data-copy-label>Copy Email</span>
          </button>

          <a
            href="/resume.pdf"
            download
            class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-5 py-3 rounded-md font-medium hover:bg-muted focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background transition-colors cursor-pointer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
              ></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="12" y1="18" x2="12" y2="12"></line>
              <line x1="9" y1="15" x2="15" y2="15"></line>
            </svg>
            Download Resume
          </a>
        </div>

        <p class="text-xs italic text-muted-foreground mt-5">
          Usually replies within a few days.
        </p>
      </div>

      <!-- RIGHT: Contact cards -->
      <div class="lg:col-span-7 flex flex-col gap-3 stagger-children">
        {
          contactItems.map((item) => {
            const interactive = item.available && item.href;
            const Wrapper = interactive ? 'a' : 'div';
            const wrapperProps = interactive
              ? {
                  href: item.href,
                  target: item.external ? '_blank' : undefined,
                  rel: item.external ? 'noopener noreferrer' : undefined,
                  'aria-label': `${item.label}: ${item.value}`,
                }
              : {
                  'aria-disabled': !item.available ? true : undefined,
                  tabindex: !item.available ? -1 : undefined,
                };

            return (
              <Wrapper
                {...wrapperProps}
                class:list={[
                  'group flex items-center gap-4 bg-card border border-border rounded-lg p-5 transition-all duration-200 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background',
                  interactive
                    ? 'hover:border-primary/30 hover:-translate-y-0.5 hover:shadow-md cursor-pointer'
                    : item.available
                      ? 'cursor-default'
                      : 'opacity-60 cursor-not-allowed',
                ]}
              >
                <div class="w-11 h-11 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill={item.icon === 'github' ? 'currentColor' : 'none'}
                    stroke={item.icon === 'github' ? 'none' : 'currentColor'}
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={iconPath[item.icon]}
                  />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <p class="text-xs uppercase tracking-wider text-muted-foreground font-medium">
                      {item.label}
                    </p>
                  </div>
                  <p class="text-sm text-foreground mt-1 font-medium break-all sm:break-normal sm:truncate">
                    {item.value}
                  </p>
                </div>
                {item.available && item.external && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-muted-foreground shrink-0 hidden sm:block"
                    aria-hidden="true"
                  >
                    <path d="M15 3h6v6" />
                    <path d="M10 14 21 3" />
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  </svg>
                )}
                {item.available && !item.external && item.href && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-muted-foreground shrink-0 hidden sm:block"
                    aria-hidden="true"
                  >
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                )}
              </Wrapper>
            );
          })
        }
      </div>
    </div>

    <hr class="border-t border-border my-12" />

    <footer>
      <div
        class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
      >
        <div class="text-xs text-muted-foreground space-y-1">
          <p>&copy; 2026 Nikko Causapin</p>
          <p>Built with Astro · Commit {buildSha}</p>
        </div>
        <button
          id="back-to-top"
          type="button"
          class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors cursor-pointer focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm"
          aria-label="Back to top"
        >
          Back to top
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="18 15 12 9 6 15"></polyline>
          </svg>
        </button>
      </div>
    </footer>
  </div>
</section>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  const copyButton = document.querySelector('[data-copy-email]');
  const copyLabel = copyButton?.querySelector('[data-copy-label]');

  copyButton?.addEventListener('click', async () => {
    const email = copyButton.getAttribute('data-copy-value') || '';

    try {
      await navigator.clipboard.writeText(email);
      if (copyLabel) copyLabel.textContent = 'Email Copied';
      window.setTimeout(() => {
        if (copyLabel) copyLabel.textContent = 'Copy Email';
      }, 1800);
    } catch {
      if (copyLabel) copyLabel.textContent = 'Copy Email';
      window.location.href = `mailto:${email}`;
    }
  });
</script>
