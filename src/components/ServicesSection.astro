---

<section id="services" class="scroll-reveal">
  <div class="max-w-4xl lg:max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-semibold leading-tight text-foreground mb-8">
      Services
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
      <div class="bg-card border border-border rounded-lg p-6 transition-all duration-200 hover:border-primary/30 hover:bg-muted/30 group cursor-default">
        <div class="mb-4 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">
          Full-stack Development
        </h3>
        <p class="text-base text-muted-foreground">
          End-to-end web application development from database to deployment.
        </p>
      </div>
      <div class="bg-card border border-border rounded-lg p-6 transition-all duration-200 hover:border-primary/30 hover:bg-muted/30 group cursor-default">
        <div class="mb-4 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">
          Clean UI Implementation
        </h3>
        <p class="text-base text-muted-foreground">
          Polished, responsive interfaces built with attention to detail.
        </p>
      </div>
      <div class="bg-card border border-border rounded-lg p-6 transition-all duration-200 hover:border-primary/30 hover:bg-muted/30 group cursor-default">
        <div class="mb-4 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18" /><path d="m19 9-5 5-4-4-3 3" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">
          Analytics & Dashboards
        </h3>
        <p class="text-base text-muted-foreground">
          Data-driven reporting and visualization for informed decision-making.
        </p>
      </div>
      <div class="bg-card border border-border rounded-lg p-6 transition-all duration-200 hover:border-primary/30 hover:bg-muted/30 group cursor-default">
        <div class="mb-4 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z" /><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">
          Internal Tools & Automation
        </h3>
        <p class="text-base text-muted-foreground">
          Custom workflow automation and tooling to streamline operations.
        </p>
      </div>
    </div>
  </div>
</section>