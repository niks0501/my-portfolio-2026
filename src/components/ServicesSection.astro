---
const services = [
  {
    n: '01',
    title: 'Full-stack Development',
    desc: 'End-to-end web application development from database to deployment.',
    icon: 'code',
  },
  {
    n: '02',
    title: 'Clean UI Implementation',
    desc: 'Polished, responsive interfaces built with attention to detail.',
    icon: 'layout',
  },
  {
    n: '03',
    title: 'Analytics & Dashboards',
    desc: 'Data-driven reporting and visualization for informed decision-making.',
    icon: 'chart',
  },
  {
    n: '04',
    title: 'Internal Tools & Automation',
    desc: 'Custom workflow automation and tooling to streamline operations.',
    icon: 'cog',
  },
] as const;

const icons: Record<string, string> = {
  code: '<polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />',
  layout:
    '<rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" />',
  chart: '<path d="M3 3v18h18" /><path d="m19 9-5 5-4-4-3 3" />',
  cog: '<path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z" /><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />',
};
---

<section
  id="services"
  class="scroll-reveal bg-gradient-to-b from-transparent via-sky-500/[0.025] to-sky-500/[0.035] dark:via-sky-400/[0.06] dark:to-sky-400/[0.08]"
>
  <div class="max-w-4xl lg:max-w-7xl mx-auto px-6 py-16">
    <div
      class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10"
    >
      <div>
        <p
          class="text-xs font-medium uppercase tracking-[0.18em] text-primary mb-3"
        >
          What I Do
        </p>
        <h2 class="text-2xl font-semibold leading-tight text-foreground">
          Services
        </h2>
        <div
          class="w-12 h-px bg-gradient-to-r from-primary/60 to-transparent mt-4"
          aria-hidden="true"
        >
        </div>
      </div>
      <p
        class="text-xs font-medium text-muted-foreground tabular-nums shrink-0 sm:pb-1"
      >
        04 services
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
      {
        services.map((s) => (
          <div class="relative glass-card p-6 group cursor-default">
            <div class="absolute top-4 right-4 flex flex-col items-end gap-1.5">
              <span class="text-xs font-medium tabular-nums text-muted-foreground dark:text-foreground/75">
                {s.n}
              </span>
              <span
                class="text-primary opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </div>
            <div class="mb-5 w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center text-primary transition-transform duration-200 group-hover:scale-110 dark:bg-primary/25">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[s.icon]}
              />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">
              {s.title}
            </h3>
            <p class="text-base text-muted-foreground dark:text-foreground/[0.85]">
              {s.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
