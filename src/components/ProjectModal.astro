---
import { Icon } from 'astro-icon/components';
import type { Project, ProjectCategory } from '../types/project';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const statusLabel: Record<Project['status'], string> = {
  live: 'Live',
  'in-progress': 'In progress',
  archived: 'Archived',
};

const statusClasses: Record<Project['status'], string> = {
  live: 'bg-green-500/10 text-green-700 dark:text-green-400 border-green-500/20',
  'in-progress':
    'bg-amber-500/10 text-amber-700 dark:text-amber-400 border-amber-500/20',
  archived: 'bg-muted text-muted-foreground border-border',
};

const categoryLabel: Record<ProjectCategory, string> = {
  'web-app': 'Web App',
  data: 'Data',
  tool: 'Tool',
};

const stackGroupLabel: Record<Project['stack'][number]['group'], string> = {
  frontend: 'Frontend',
  backend: 'Backend',
  data: 'Data',
};

const stackGroupIcon: Record<Project['stack'][number]['group'], string> = {
  frontend: 'tabler:browser',
  backend: 'tabler:server-2',
  data: 'tabler:database',
};
---

<dialog
  id="project-modal"
  aria-labelledby="project-modal-title"
  class="rounded-2xl p-0 w-[min(56rem,95vw)] max-w-3xl max-h-[90vh] border border-border bg-background text-foreground overflow-hidden backdrop:bg-black/50"
  data-project-modal
>
  <div class="flex flex-col max-h-[90vh]">
    <header
      class="flex items-start justify-between gap-4 px-6 pt-6 pb-4 border-b border-border"
    >
      <div class="min-w-0 flex-1">
        <div
          class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground mb-2"
        >
          <div
            data-modal-categories
            class="flex flex-wrap items-center gap-1.5"
          >
          </div>
          <span data-modal-meta class="font-heading tabular-nums"></span>
          <span
            data-modal-status
            class="inline-flex items-center gap-1 text-[10px] font-medium uppercase tracking-[0.1em] px-2 py-0.5 rounded-full border"
          >
            <span
              class="w-1.5 h-1.5 rounded-full"
              data-modal-status-dot
              aria-hidden="true"></span>
            <span data-modal-status-label></span>
          </span>
        </div>
        <h2
          id="project-modal-title"
          data-modal-title
          class="text-2xl lg:text-3xl font-semibold leading-tight text-foreground"
        >
        </h2>
      </div>
      <button
        type="button"
        data-modal-close
        aria-label="Close case study"
        class="shrink-0 text-muted-foreground hover:text-foreground hover:bg-muted text-xl leading-none cursor-pointer rounded-full w-9 h-9 flex items-center justify-center transition-colors focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      >
        &times;
      </button>
    </header>

    <div class="flex-1 overflow-y-auto px-6 py-6 space-y-8">
      <section aria-label="Screenshots" class="-mx-6">
        <div
          data-modal-image-stage
          class="relative flex items-center justify-center gap-3 px-6"
        >
          <div
            data-modal-progress
            class="absolute top-0 left-6 right-6 h-[2px] bg-primary/40 rounded-full origin-left"
            style="transform: scaleX(0)"
            aria-hidden="true"
          >
          </div>
          <button
            type="button"
            data-modal-gallery-prev
            class="hidden sm:flex shrink-0 text-muted-foreground hover:text-foreground hover:bg-muted text-2xl cursor-pointer rounded-xl w-10 h-10 items-center justify-center transition-colors focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
            aria-label="Previous screenshot"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><polyline points="15 18 9 12 15 6"></polyline></svg
            >
          </button>
          <div
            class="flex-1 min-w-0 h-[300px] sm:h-[400px] flex items-center justify-center bg-muted/30 rounded-lg overflow-hidden border border-border shadow-sm"
          >
            <div class="w-full h-full relative">
              <img
                data-modal-image
                src=""
                alt=""
                class="absolute inset-0 w-full h-full object-contain transition-opacity duration-300"
                style="opacity: 1"
              />
            </div>
          </div>
          <button
            type="button"
            data-modal-gallery-next
            class="hidden sm:flex shrink-0 text-muted-foreground hover:text-foreground hover:bg-muted text-2xl cursor-pointer rounded-xl w-10 h-10 items-center justify-center transition-colors focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
            aria-label="Next screenshot"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><polyline points="9 18 15 12 9 6"></polyline></svg
            >
          </button>
        </div>
        <div class="flex items-center justify-between gap-3 mt-3 px-6">
          <div data-modal-gallery-dots class="flex gap-1.5"></div>
          <div data-modal-gallery-controls class="flex items-center gap-2">
            <span
              data-modal-gallery-counter
              class="text-xs text-muted-foreground tabular-nums"></span>
            <span
              data-modal-autoplay-dot
              class="inline-flex items-center gap-1.5 text-[10px] font-medium uppercase tracking-[0.12em] text-muted-foreground"
              aria-label="Slideshow active"
            >
              <span
                class="w-2 h-2 rounded-full bg-primary animate-pulse"
                aria-hidden="true"></span>
              Auto
            </span>
          </div>
        </div>
        <p
          data-modal-gallery-caption
          class="flex items-start gap-3 text-sm text-muted-foreground mt-2 px-6 border-l-2 border-border pl-6 ml-6"
        >
        </p>
      </section>

      <section>
        <h3
          class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground mb-2"
        >
          Overview
        </h3>
        <p
          data-modal-description
          class="text-base text-foreground leading-relaxed"
        >
        </p>
      </section>

      <section>
        <h3
          class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground mb-3"
        >
          Highlights
        </h3>
        <ul data-modal-highlights class="space-y-2"></ul>
      </section>

      <section>
        <h3
          class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground mb-3"
        >
          Outcomes
        </h3>
        <dl data-modal-metrics class="grid grid-cols-3 gap-3 sm:gap-4"></dl>
      </section>

      <section>
        <h3
          class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground mb-3"
        >
          Stack
        </h3>
        <div data-modal-stack class="space-y-3"></div>
      </section>

      <section>
        <h3
          class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground mb-3"
        >
          Challenges &amp; Learnings
        </h3>
        <ul data-modal-challenges class="space-y-2"></ul>
      </section>
    </div>

    <footer
      class="flex flex-wrap items-center justify-between gap-3 px-6 py-4 border-t border-border bg-muted/20"
    >
      <a
        data-modal-github
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium bg-foreground text-background px-4 py-2 rounded-md hover:brightness-90 transition-[filter] focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        View source
      </a>
      <a
        data-modal-demo
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-sm font-medium border border-border text-foreground px-4 py-2 rounded-md hover:bg-muted transition-colors focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      >
        Live demo
      </a>
    </footer>
  </div>
</dialog>

<style is:global>
  #project-modal[open] {
    animation: project-modal-in 0.22s ease-out;
  }

  #project-modal[open]::backdrop {
    animation: project-backdrop-in 0.22s ease-out;
  }

  #project-modal {
    margin: auto;
  }

  @keyframes project-modal-in {
    from {
      opacity: 0;
      transform: scale(0.94) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes project-backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #project-modal[open],
    #project-modal[open]::backdrop {
      animation: none;
    }
  }
</style>

<script
  type="application/json"
  data-projects-payload
  set:html={JSON.stringify(projects)}
/>

<script>
  type Status = 'live' | 'in-progress' | 'archived';
  type Category = 'web-app' | 'data' | 'tool';
  type StackGroup = 'frontend' | 'backend' | 'data';

  interface Project {
    slug: string;
    title: string;
    summary: string;
    longDescription: string;
    highlights: string[];
    challenges: string[];
    tags: { label: string; icon: string }[];
    stack: { label: string; group: StackGroup }[];
    metrics: { value: string; label: string }[];
    image: string;
    gallery: { src: string; alt: string; caption?: string }[];
    githubUrl: string;
    liveDemoUrl: string | null;
    featured: boolean;
    categories: Category[];
    year: string;
    role: string;
    status: Status;
    accent: string;
  }

  const CATEGORY_LABEL: Record<Category, string> = {
    'web-app': 'Web App',
    data: 'Data',
    tool: 'Tool',
  };

  const STATUS_LABEL: Record<Status, string> = {
    live: 'Live',
    'in-progress': 'In progress',
    archived: 'Archived',
  };

  const STATUS_DOT: Record<Status, string> = {
    live: 'bg-green-500',
    'in-progress': 'bg-amber-500',
    archived: 'bg-muted-foreground',
  };

  const STATUS_BADGE: Record<Status, string> = {
    live: 'bg-green-500/10 text-green-700 dark:text-green-400 border-green-500/20',
    'in-progress':
      'bg-amber-500/10 text-amber-700 dark:text-amber-400 border-amber-500/20',
    archived: 'bg-muted text-muted-foreground border-border',
  };

  const STACK_GROUP_LABEL: Record<StackGroup, string> = {
    frontend: 'Frontend',
    backend: 'Backend',
    data: 'Data',
  };

  const STACK_GROUP_ICON: Record<StackGroup, string> = {
    frontend: 'tabler:browser',
    backend: 'tabler:server-2',
    data: 'tabler:database',
  };

  const payload = document.querySelector<HTMLScriptElement>(
    '[data-projects-payload]',
  );
  if (!payload?.textContent) {
    throw new Error('Project data payload missing');
  }
  const projects: Project[] = JSON.parse(payload.textContent);
  const bySlug = new Map(projects.map((p) => [p.slug, p]));

  const dialog = document.getElementById('project-modal') as HTMLDialogElement;
  const els = {
    title: dialog.querySelector<HTMLElement>('[data-modal-title]')!,
    categories: dialog.querySelector<HTMLElement>('[data-modal-categories]')!,
    meta: dialog.querySelector<HTMLElement>('[data-modal-meta]')!,
    status: dialog.querySelector<HTMLElement>('[data-modal-status]')!,
    statusLabel: dialog.querySelector<HTMLElement>(
      '[data-modal-status-label]',
    )!,
    statusDot: dialog.querySelector<HTMLElement>('[data-modal-status-dot]')!,
    image: dialog.querySelector<HTMLImageElement>('[data-modal-image]')!,
    description: dialog.querySelector<HTMLElement>('[data-modal-description]')!,
    highlights: dialog.querySelector<HTMLElement>('[data-modal-highlights]')!,
    metrics: dialog.querySelector<HTMLElement>('[data-modal-metrics]')!,
    stack: dialog.querySelector<HTMLElement>('[data-modal-stack]')!,
    challenges: dialog.querySelector<HTMLElement>('[data-modal-challenges]')!,
    github: dialog.querySelector<HTMLAnchorElement>('[data-modal-github]')!,
    demo: dialog.querySelector<HTMLAnchorElement>('[data-modal-demo]')!,
    prev: dialog.querySelector<HTMLButtonElement>('[data-modal-gallery-prev]')!,
    next: dialog.querySelector<HTMLButtonElement>('[data-modal-gallery-next]')!,
    dots: dialog.querySelector<HTMLElement>('[data-modal-gallery-dots]')!,
    counter: dialog.querySelector<HTMLElement>('[data-modal-gallery-counter]')!,
    caption: dialog.querySelector<HTMLElement>('[data-modal-gallery-caption]')!,
    controls: dialog.querySelector<HTMLElement>(
      '[data-modal-gallery-controls]',
    )!,
    close: dialog.querySelector<HTMLButtonElement>('[data-modal-close]')!,
  };

  let active: Project | null = null;
  let galleryIndex = 0;
  let lastFocused: HTMLElement | null = null;

  const baseStatusClasses = els.status.className;
  const baseStatusDotClasses = els.statusDot.className;

  const reducedMotionQuery = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  );
  let reducedMotion = reducedMotionQuery.matches;
  let autoplayTimer: ReturnType<typeof setInterval> | null = null;
  let resumeTimer: ReturnType<typeof setTimeout> | null = null;
  let isPausedByUser = false;
  let isAutoplayWanted = false;
  let galleryRenderToken = 0;
  const AUTOPLAY_INTERVAL_MS = 3500;

  const setText = (el: HTMLElement, text: string) => {
    el.textContent = text;
  };

  const renderHighlights = (items: string[]) => {
    els.highlights.innerHTML = items
      .map(
        (h) => `
        <li class="flex items-start gap-2 text-base text-foreground leading-relaxed">
          <span class="text-primary mt-1 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
          <span>${h}</span>
        </li>`,
      )
      .join('');
  };

  const renderChallenges = (items: string[]) => {
    els.challenges.innerHTML = items
      .map(
        (c) => `
        <li class="flex items-start gap-2 text-base text-foreground leading-relaxed">
          <span class="text-muted-foreground mt-0.5 shrink-0" aria-hidden="true">&mdash;</span>
          <span>${c}</span>
        </li>`,
      )
      .join('');
  };

  const renderMetrics = (metrics: Project['metrics']) => {
    els.metrics.innerHTML = metrics
      .map(
        (m) => `
        <div class="border-l-2 border-border pl-3 py-1">
          <dt class="text-[10px] font-medium uppercase tracking-[0.12em] text-muted-foreground">${m.label}</dt>
          <dd class="text-xl sm:text-2xl font-heading font-semibold text-foreground mt-0.5">${m.value}</dd>
        </div>`,
      )
      .join('');
  };

  const renderStack = (stack: Project['stack']) => {
    const groups: StackGroup[] = ['frontend', 'backend', 'data'];
    const icons: Record<StackGroup, string> = {
      frontend:
        '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="14" rx="2"></rect><path d="M2 8h20"></path></svg>',
      backend:
        '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="8" rx="2"></rect><rect x="2" y="13" width="20" height="8" rx="2"></rect><path d="M6 7h.01M6 17h.01"></path></svg>',
      data: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14a9 3 0 0 0 18 0V5"></path></svg>',
    };
    els.stack.innerHTML = groups
      .map((group) => {
        const items = stack.filter((s) => s.group === group);
        if (items.length === 0) return '';
        return `
        <div class="flex items-start gap-3">
          <div class="shrink-0 mt-0.5 inline-flex items-center gap-1.5 text-[10px] font-medium uppercase tracking-[0.12em] text-muted-foreground w-20">
            <span class="text-primary">${icons[group]}</span>
            ${STACK_GROUP_LABEL[group]}
          </div>
          <div class="flex flex-wrap gap-1.5">
            ${items
              .map(
                (s) =>
                  `<span class="text-xs bg-muted text-foreground px-2.5 py-1 rounded-md">${s.label}</span>`,
              )
              .join('')}
          </div>
        </div>`;
      })
      .join('');
  };

  const renderGallery = (project: Project) => {
    const total = project.gallery.length;
    const showControls = total > 1;
    els.prev.classList.toggle('hidden', !showControls);
    els.next.classList.toggle('hidden', !showControls);
    els.controls.classList.toggle('hidden', !showControls);

    if (showControls) {
      els.dots.innerHTML = project.gallery
        .map(
          (_, i) =>
            `<button type="button" data-modal-dot="${i}" class="w-1.5 h-1.5 rounded-full ${i === galleryIndex ? 'bg-foreground' : 'bg-border'} hover:bg-muted-foreground transition-colors focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" aria-label="Go to screenshot ${i + 1}"></button>`,
        )
        .join('');
      els.counter.textContent = `${galleryIndex + 1} / ${total}`;
    } else {
      els.counter.textContent = '';
    }
  };

  const elProgress = dialog.querySelector<HTMLElement>(
    '[data-modal-progress]',
  )!;

  const showGalleryAt = (index: number, project: Project) => {
    if (!project.gallery.length) return;
    const total = project.gallery.length;
    galleryIndex = ((index % total) + total) % total;
    const item = project.gallery[galleryIndex];
    const renderToken = ++galleryRenderToken;

    els.image.onload = null;
    els.image.onerror = null;
    els.caption.textContent = item.caption ?? '';
    elProgress.style.transition = 'none';
    elProgress.style.transform = 'scaleX(0)';

    const reveal = () => {
      if (renderToken !== galleryRenderToken) return;
      els.image.onload = null;
      els.image.onerror = null;
      els.image.style.opacity = '1';

      if (!reducedMotion && total > 1) {
        requestAnimationFrame(() => {
          if (renderToken !== galleryRenderToken) return;
          elProgress.style.transition = `transform ${AUTOPLAY_INTERVAL_MS}ms linear`;
          elProgress.style.transform = 'scaleX(1)';
        });
      }
    };

    if (!reducedMotion) {
      els.image.style.opacity = '0';
      requestAnimationFrame(() => {
        if (renderToken !== galleryRenderToken) return;
        els.image.onload = reveal;
        els.image.onerror = reveal;
        els.image.src = item.src;
        els.image.alt = item.alt;

        if (els.image.complete) {
          reveal();
        }
      });
    } else {
      els.image.src = item.src;
      els.image.alt = item.alt;
      reveal();
    }

    if (project.gallery.length > 1) {
      const dots = els.dots.querySelectorAll<HTMLButtonElement>(
        'button[data-modal-dot]',
      );
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-foreground', i === galleryIndex);
        dot.classList.toggle('bg-border', i !== galleryIndex);
      });
      els.counter.textContent = `${galleryIndex + 1} / ${total}`;
    }
  };

  const renderCategories = (
    categories: Project['categories'],
    accent: string,
  ) => {
    els.categories.innerHTML = categories
      .map(
        (cat) => `
        <span class="inline-flex items-center gap-1.5 text-[10px] font-medium uppercase tracking-[0.12em] px-2 py-0.5 rounded-md border border-border bg-muted/40 text-foreground">
          <span class="w-1.5 h-1.5 rounded-full" style="background-color: ${accent}" aria-hidden="true"></span>
          ${CATEGORY_LABEL[cat]}
        </span>`,
      )
      .join('');
  };

  const autoplayDot = dialog.querySelector<HTMLElement>(
    '[data-modal-autoplay-dot]',
  )!;

  const stopAutoplay = () => {
    if (autoplayTimer) {
      clearInterval(autoplayTimer);
      autoplayTimer = null;
    }
    if (resumeTimer) {
      clearTimeout(resumeTimer);
      resumeTimer = null;
    }
    autoplayDot.classList.add('hidden');
  };

  const shouldAutoplay = () =>
    !reducedMotion && dialog.open && active && active.gallery.length > 1;

  const startAutoplay = () => {
    isAutoplayWanted = true;
    if (!shouldAutoplay()) return;
    stopAutoplay();
    isPausedByUser = false;
    autoplayDot.classList.remove('hidden');
    autoplayTimer = setInterval(() => {
      if (active) showGalleryAt(galleryIndex + 1, active);
    }, AUTOPLAY_INTERVAL_MS);
  };

  const resetAutoplayAfterInteraction = () => {
    if (reducedMotion) return;
    stopAutoplay();
    isAutoplayWanted = false;
    autoplayDot.classList.add('hidden');
    isPausedByUser = true;
    if (active && active.gallery.length > 1) {
      resumeTimer = setTimeout(() => {
        startAutoplay();
      }, 6000);
    }
  };
  const populate = (project: Project) => {
    active = project;
    galleryIndex = 0;

    setText(els.title, project.title);
    renderCategories(project.categories, project.accent);
    setText(els.meta, `${project.year} · ${project.role}`);

    els.status.className = baseStatusClasses;
    els.statusDot.className = baseStatusDotClasses;
    setText(els.statusLabel, STATUS_LABEL[project.status]);
    STATUS_BADGE[project.status]
      .split(' ')
      .forEach((c) => els.status.classList.add(c));
    STATUS_DOT[project.status]
      .split(' ')
      .forEach((c) => els.statusDot.classList.add(c));

    setText(els.description, project.longDescription);
    renderHighlights(project.highlights);
    renderMetrics(project.metrics);
    renderStack(project.stack);
    renderChallenges(project.challenges);
    renderGallery(project);

    showGalleryAt(0, project);

    els.github.href = project.githubUrl;
    els.github.setAttribute('aria-label', `${project.title} source on GitHub`);
    if (project.liveDemoUrl) {
      els.demo.href = project.liveDemoUrl;
      els.demo.classList.remove('hidden');
      els.demo.setAttribute('aria-label', `${project.title} live demo`);
    } else {
      els.demo.classList.add('hidden');
    }
  };

  const focusableSelector =
    'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';

  const trapFocus = (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusables = Array.from(
      dialog.querySelectorAll<HTMLElement>(focusableSelector),
    ).filter((el) => !el.hasAttribute('disabled') && el.offsetParent !== null);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  };

  const open = (slug: string) => {
    const project = bySlug.get(slug);
    if (!project) return;
    populate(project);
    lastFocused = document.activeElement as HTMLElement | null;
    dialog.showModal();
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      startAutoplay();
    });
    requestAnimationFrame(() => {
      const firstFocusable =
        dialog.querySelector<HTMLElement>(focusableSelector);
      firstFocusable?.focus();
    });
  };

  const close = () => {
    stopAutoplay();
    isAutoplayWanted = false;
    dialog.close();
    document.body.style.overflow = '';
    lastFocused?.focus();
    active = null;
  };

  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const trigger = target.closest<HTMLElement>('[data-project-trigger]');
    if (trigger) {
      const slug = trigger.getAttribute('data-project-trigger');
      if (slug) {
        e.preventDefault();
        open(slug);
      }
      return;
    }
    if (target === dialog) {
      close();
    }
  });

  dialog.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    if (target.closest('[data-modal-close]')) {
      e.preventDefault();
      close();
      return;
    }
    if (active && target.closest('[data-modal-gallery-prev]')) {
      e.preventDefault();
      showGalleryAt(galleryIndex - 1, active);
      resetAutoplayAfterInteraction();
      return;
    }
    if (active && target.closest('[data-modal-gallery-next]')) {
      e.preventDefault();
      showGalleryAt(galleryIndex + 1, active);
      resetAutoplayAfterInteraction();
      return;
    }
    const dot = target.closest<HTMLElement>('[data-modal-dot]');
    if (dot && active) {
      const idx = Number(dot.getAttribute('data-modal-dot'));
      if (!Number.isNaN(idx)) {
        showGalleryAt(idx, active);
        resetAutoplayAfterInteraction();
      }
    }
  });

  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      e.preventDefault();
      close();
      return;
    }
    if (!active) return;
    if (e.key === 'ArrowLeft' && active.gallery.length > 1) {
      e.preventDefault();
      showGalleryAt(galleryIndex - 1, active);
      resetAutoplayAfterInteraction();
    } else if (e.key === 'ArrowRight' && active.gallery.length > 1) {
      e.preventDefault();
      showGalleryAt(galleryIndex + 1, active);
      resetAutoplayAfterInteraction();
    } else {
      trapFocus(e);
    }
  });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      stopAutoplay();
    } else if (isAutoplayWanted && !isPausedByUser) {
      startAutoplay();
    }
  });

  reducedMotionQuery.addEventListener('change', (e) => {
    reducedMotion = e.matches;
    if (reducedMotion) {
      stopAutoplay();
      return;
    }
    if (isAutoplayWanted && !isPausedByUser) {
      startAutoplay();
    }
  });

  dialog.addEventListener('close', () => {
    stopAutoplay();
    isAutoplayWanted = false;
    active = null;
  });
</script>
