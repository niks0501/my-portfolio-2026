---
import ProjectCard from './ProjectCard.astro';
import { getProjects } from '../lib/projects';
import type { ProjectCategory } from '../types/project';

const projects = await getProjects();
const featuredProject = projects.find((project) => project.featured);
const standardProjects = projects.filter((project) => !project.featured);
const orderedProjects = featuredProject
  ? [
      ...standardProjects.slice(0, 1),
      featuredProject,
      ...standardProjects.slice(1),
    ]
  : projects;

const filters: { id: 'all' | ProjectCategory; label: string }[] = [
  { id: 'all', label: 'All' },
  { id: 'web-app', label: 'Web Apps' },
  { id: 'data', label: 'Data' },
  { id: 'tool', label: 'Tools' },
];
---

<section
  id="projects"
  class="scroll-reveal bg-gradient-to-b from-primary/[0.035] via-primary/[0.02] to-transparent dark:from-primary/[0.08] dark:via-primary/[0.035]"
>
  <div class="max-w-4xl lg:max-w-7xl mx-auto px-6 py-16">
    <div
      class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-8"
    >
      <div>
        <p
          class="text-xs font-medium uppercase tracking-[0.18em] text-primary mb-3"
        >
          Selected work
        </p>
        <h2 class="text-2xl font-semibold leading-tight text-foreground">
          Projects
        </h2>
        <p
          class="text-base text-muted-foreground mt-2 max-w-xl dark:text-foreground/[0.85]"
        >
          Web apps and internal tools with a focus on clean UI and analytics
          that make decisions easier.
        </p>
      </div>

      <div
        class="flex flex-nowrap sm:flex-wrap items-center gap-2 overflow-x-auto sm:overflow-visible -mx-6 px-6 sm:mx-0 sm:px-0"
        aria-label="Filter projects by category"
        data-projects-filters
      >
        {
          filters.map((filter, i) => (
            <button
              type="button"
              data-filter={filter.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
              class:list={[
                'shrink-0 text-sm font-medium px-3.5 py-1.5 rounded-md transition-colors cursor-pointer',
                'focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background',
                i === 0
                  ? 'bg-foreground text-background border border-foreground'
                  : 'glass text-muted-foreground hover:text-foreground',
              ]}
            >
              {filter.label}
            </button>
          ))
        }
      </div>
    </div>

    <div
      class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-6 md:grid-cols-3 lg:gap-8"
      data-projects-grid
    >
      {
        orderedProjects.map((project) => (
          <ProjectCard
            {...project}
            variant={project.featured ? 'featured' : 'standard'}
          />
        ))
      }
    </div>
  </div>
</section>
