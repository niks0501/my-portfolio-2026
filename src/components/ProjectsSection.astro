---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: 'Pig-Sikap',
    summary:
      'A web-based system that helps pig farmers manage inventory, health records, expenses, sales, reports, and profitability insights.',
    highlights: [
      'Pig inventory and cycle management',
      'Health records and health task tracking',
      'Profitability and profit-sharing reports',
    ],
    tags: [
      { label: 'Laravel', icon: 'tabler:brand-laravel' },
      { label: 'Vue', icon: 'tabler:brand-vue' },
      { label: 'Tailwind', icon: 'tabler:brand-tailwind' },
      { label: 'MySQL', icon: 'tabler:database' },
      { label: 'Analytics', icon: 'tabler:chart-bar' },
      { label: 'Livestock Mgmt', icon: 'tabler:paw' },
    ],
    image: '/images/projects/pig-sikap/dashboard.png',
    githubUrl: 'https://github.com/niks0501/pig-sikap',
    liveDemoUrl: undefined as string | undefined,
  },
  {
    title: 'Dirty2Data',
    summary:
      'A Laravel + Inertia + React data cleaning and analytics system for uploading, profiling, cleaning, analyzing, and visualizing datasets.',
    highlights: [
      'Dataset upload and profiling',
      'Cleaning workflow with recommendations and undo',
      'Analytics dashboards, visualizations, and insights',
    ],
    tags: [
      { label: 'Laravel', icon: 'tabler:brand-laravel' },
      { label: 'Inertia', icon: 'tabler:brand-inertia' },
      { label: 'React', icon: 'tabler:brand-react' },
      { label: 'TypeScript', icon: 'tabler:brand-typescript' },
      { label: 'Tailwind', icon: 'tabler:brand-tailwind' },
      { label: 'Data Analytics', icon: 'tabler:chart-dots' },
    ],
    image: '/images/projects/dirty2data/dashboard.png',
    githubUrl: 'https://github.com/niks0501/dirty2data',
    liveDemoUrl: undefined as string | undefined,
  },
  {
    title: 'LumbanganSystem',
    summary:
      'A web-based Barangay Management Information System for resident records, document requests, approvals, and barangay service workflows.',
    highlights: [
      'Document requests with status tracking',
      'Document types/templates and proof uploads',
      'Admin dashboard and statistics',
    ],
    tags: [
      { label: 'PHP', icon: 'tabler:brand-php' },
      { label: 'MySQL', icon: 'tabler:database' },
      { label: 'MVC', icon: 'tabler:code' },
      { label: 'Bootstrap', icon: 'tabler:brand-bootstrap' },
      { label: 'Barangay System', icon: 'tabler:building-community' },
    ],
    image: '/images/projects/lumbangan-system/dashboard.png',
    githubUrl: 'https://github.com/alfredD-12/LumbanganSystem',
    liveDemoUrl: undefined as string | undefined,
  },
];
---

<section id="projects" class="scroll-reveal">
  <div class="max-w-4xl lg:max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-semibold leading-tight text-foreground mb-10">
      Projects
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </div>
</section>
